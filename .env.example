# Runtime
NODE_ENV=production
# Host port exposed by docker-compose (change if 3232 is occupied).
HOST_PORT=3232
PORT=3232
SWAGGER_ENABLED=false
CORS_ALLOW_LOCALHOST=false

# Rate limit
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# Auth
# Generate on the server: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=30d
BCRYPT_SALT=10

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mk_academy

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mk_academy?schema=public"
DOCKER_DATABASE_URL="postgresql://postgres:postgres@postgres:5432/mk_academy?schema=public"

# Frontend
FRONTEND_URL=https://mk-academia.uz

